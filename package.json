{
  "name": "generativist-pi",
  "version": "0.0.1",
  "description": "Portable Pi package for the Generativist Pi configuration.",
  "private": true,
  "keywords": [
    "pi-package",
    "pi",
    "pi-config"
  ],
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/jbn/generativist-pi.git"
  },
  "dependencies": {
    "@juicesharp/rpiv-ask-user-question": "1.20.0",
    "pi-powerline-footer": "0.6.1",
    "pi-simplify": "0.2.2",
    "pi-subagents": "0.28.0"
  },
  "bundledDependencies": [
    "@juicesharp/rpiv-ask-user-question",
    "pi-powerline-footer",
    "pi-simplify",
    "pi-subagents"
  ],
  "pi": {
    "extensions": [
      "./extensions",
      "./node_modules/pi-powerline-footer/index.ts",
      "./node_modules/@juicesharp/rpiv-ask-user-question/index.ts",
      "./node_modules/pi-simplify/dist/index.js",
      "./node_modules/pi-subagents/src/extension/index.ts"
    ],
    "skills": [
      "./skills",
      "./node_modules/pi-subagents/skills"
    ],
    "prompts": [
      "./prompts",
      "./node_modules/pi-subagents/prompts"
    ],
    "themes": [
      "./themes"
    ]
  }
}
